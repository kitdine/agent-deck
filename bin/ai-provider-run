#!/usr/bin/env python3
import argparse

from ai_provider_usage import run_client


def main():
    parser = argparse.ArgumentParser(prog="ai-provider-run")
    parser.add_argument("client", choices=("codex", "claude"))
    parser.add_argument("arguments", nargs=argparse.REMAINDER)
    values = parser.parse_args()
    raise SystemExit(run_client(values.client, values.arguments))


if __name__ == "__main__":
    main()
